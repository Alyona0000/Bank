{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build main.exe",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "Set-Location -Path '${workspaceFolder}'; $files = Get-ChildItem -Filter '*.cpp' -Name; & 'C:\\msys64\\bin\\g++.exe' -g -static-libstdc++ -static-libgcc $files -o 'main.exe'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}